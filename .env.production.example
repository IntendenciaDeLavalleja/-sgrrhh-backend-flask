# ============================================================
# Variables de entorno para deploy en Coolify (producción)
# Copiar a Coolify como variables de entorno. No commitear con valores reales.
# ============================================================

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_APP=wsgi.py
SECRET_KEY=CHANGE_ME_USE_A_LONG_RANDOM_STRING

# ── Gunicorn ─────────────────────────────────────────────────────────────────
APP_MODULE=app:create_app()
PORT=5000
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# ── Base de datos (MariaDB) ───────────────────────────────────────────────────
# Formato: mariadb+mariadbconnector://user:password@host:port/dbname
DATABASE_URL=mariadb+mariadbconnector://user:password@host:3306/dbname

# ── Comportamiento de arranque ───────────────────────────────────────────────
# WAIT_FOR_DB: esperar que el puerto TCP de la BD esté disponible
WAIT_FOR_DB=true
DB_WAIT_TIMEOUT=60

# RUN_MIGRATIONS: por defecto false — las migraciones son un proceso controlado.
# Cambiar a true solo cuando se quiere aplicar migraciones en ese deploy.
# Requiere que migrations/ esté presente en la imagen (commitear en Git).
RUN_MIGRATIONS=false

# ── Prometheus ───────────────────────────────────────────────────────────────
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc_dir

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_USE_A_LONG_RANDOM_STRING

# ── Email (2FA) ──────────────────────────────────────────────────────────────
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=CHANGE_ME
MAIL_DEFAULT_SENDER=no-reply@example.com

# ── Frontend URL (para links en emails) ─────────────────────────────────────
FRONTEND_URL=https://sgrrhh.lavalleja.uy

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://sgrrhh.lavalleja.uy

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_SECURE=False
MINIO_BUCKET_NAME=gestion-recursos-humanos-uploads
